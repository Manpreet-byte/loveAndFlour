				<div class="elementor-element elementor-element-71de1580 elementor-widget elementor-widget-heading" data-id="71de1580" data-element_type="widget" data-e-type="widget" data-widget_type="heading.default">
				<div class="elementor-widget-container">
					<h6 class="elementor-heading-title elementor-size-default">From first-time home bakers to seasoned professionals, our students share how Love and Flour by Pooja's courses transformed their baking journey.</h6>				</div>
				</div>
				<div class="elementor-element elementor-element-13a66060 elementor-widget-divider--view-line elementor-widget elementor-widget-divider" data-id="13a66060" data-element_type="widget" data-e-type="widget" data-widget_type="divider.default">
