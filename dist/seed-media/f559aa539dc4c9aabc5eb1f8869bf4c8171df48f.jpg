		<script>
document.addEventListener("DOMContentLoaded", function () {

  const cards = document.querySelectorAll(".tutor-card");

  cards.forEach((card) => {
    const label = card.innerText.trim().toLowerCase();

    if (label.includes("enrolled courses")) {
      card.style.cursor = "pointer";
      card.addEventListener("click", function () {
        window.location.href = "https://loveandflourbypooja.com/dashboard/enrolled-courses/";
      });
    }

    if (label.includes("active courses")) {
      card.style.cursor = "pointer";
      card.addEventListener("click", function () {
        window.location.href = "https://loveandflourbypooja.com/dashboard/enrolled-courses/active-courses/";
      });
    }

    if (label.includes("completed courses")) {
      card.style.cursor = "pointer";
      card.addEventListener("click", function () {
        window.location.href = "https://loveandflourbypooja.com/dashboard/enrolled-courses/completed-courses/";
      });
    }

  });

});
</script>


<script>
(function () {
    const observer = new MutationObserver(() => {
        const quizLink = document.querySelector(
            '#tutor-dashboard-footer-mobile a[href*="my-quiz-attempts"]'
        );

        if (quizLink) {
            // Change link
            quizLink.href = "/dashboard/enrolled-courses/";

            // Change text
            const span = quizLink.querySelector("span");
            if (span) span.textContent = "Enrolled Courses";

            // Change icon
            const icon = quizLink.querySelector("i");
            if (icon) icon.className = "ttr tutor-icon-book-open";

            // Active state
            if (window.location.pathname.includes("/dashboard/enrolled-courses")) {
                quizLink.classList.add("active");
            }

            // Stop observing once done
            observer.disconnect();
        }
    });

    observer.observe(document.body, {
        childList: true,
        subtree: true
    });
})();
</script>


