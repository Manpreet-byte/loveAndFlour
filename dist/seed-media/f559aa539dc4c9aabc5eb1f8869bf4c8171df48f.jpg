<script type="text/javascript"></script>		<style type="text/css" id="wp-custom-css">
			/*For I-pad Footer Issue*/
footer[data-wpr-lazyrender]{
	content-visibility: visible !important;
}
/* Hide postcode field */
#billing_postcode_field {
    display: none !important;
}

/* Hide Address line 1 */
#billing_address_1_field {
    display: none !important;
}

/* Hide Address line 2 */
#billing_address_2_field {
    display: none !important;
}

/* Fix spacing after removing fields */
.woocommerce-billing-fields__field-wrapper {
    gap: 10px;
}
.woocommerce-multi-currency.wmc-switcher-layout-split.wmc-left.style-1.wmc-bottom.wmc-sidebar {display: none;}

body.woocommerce-cart .woocommerce-multi-currency.wmc-switcher-layout-split.wmc-left.style-1.wmc-bottom.wmc-sidebar, body.woocommerce-checkout .woocommerce-multi-currency.wmc-switcher-layout-split.wmc-left.style-1.wmc-bottom.wmc-sidebar {display: block;}

.woocommerce-multi-currency.wmc-switcher-layout-split.wmc-bottom.wmc-sidebar {
	display: none;
}

body.woocommerce-cart .woocommerce-multi-currency.wmc-switcher-layout-split.wmc-bottom.wmc-sidebar,
body.woocommerce-checkout .woocommerce-multi-currency.wmc-switcher-layout-split.wmc-bottom.wmc-sidebar
{
	display: block;
}

/* Blog detail page featured header image — shrink without cropping */
.single-post .rg-post-thumbnail img {
	max-height: 350px;    /* adjust as needed */
	width: auto !important;   /* don't force full width */
	height: auto !important;  /* keep natural proportions */
	object-fit: contain !important; /* ensure full image shows */
	display: block;
	margin: 0 auto;  /* center it */
}

/* Hide avatar image */
.entry-meta .avatar {
	display: none !important;
}

/* Hide author name */
.entry-meta .author.vcard {
	display: none !important;
}

/* Hide published date */
.entry-meta .posted-on {
	display: none !important;
}

/* Hide category */
.entry-meta .cat-links {
	display: none !important;
}

/* Hide Register button in header */
.header .register-button,
.header .tutor-btn-register,
.site-header .register,
.site-header a[href*="register"] {
	display: none !important;
}

.tutor-card-body .tutor-meta.tutor-mt-auto {
	display: none !important;
}
/* Change the background color of the Tutor LMS dashboard */
.tutor-dashboard {
	background-color: #f0f0f0; /* Replace with your desired color */
}

/* Change the button colors in the Tutor LMS dashboard */
.tutor-dashboard .tutor-btn {
	background-color: #F29A2A; /* Replace with your desired button background color */
	color: #ffffff; /* Replace with your desired button text color */
	border-color: #F29A2A; /* Replace border color */
}

/* Change the button hover effect */
.tutor-dashboard .tutor-btn:hover {
	background-color: #D67F14; /* Replace with your desired hover background color */
	color: #ffffff; /* Replace with your desired hover text color */
}

/* Single Courses Page  */
body.single-courses {
	background-color: #ffffff;
}

/* Account Page css*/
.tutor-dashboard .popular-courses-heading-dashboard .tutor-btn {
	color: #ffffff;
}
.tutor-dashboard .tutor-frontend-dashboard-maincontent .tutor-dashboard-left-menu,
.tutor-dashboard .tutor-frontend-dashboard-header, 
.tutor-dashboard .tutor-dashboard-content {
	background-color: #ffffff;
}

/* Single Lession page */
.tutor-lms .tutor-course-single-content-wrapper, 
.tutor-course-single-sidebar-wrapper,
body.single-lesson .tutor-course-topic-single-body, 
body.single-lesson .tutor-course-single-content-wrapper #tutor-single-entry-content .tutor-course-topic-single-header,
.tutor-course-single-content-wrapper #tutor-single-entry-content .tutor-course-topic-single-footer,
body.single-lesson #tutor-single-entry-content {
	background-color: #ffffff;
}


/* Woocommarce cart and checkout page */
body:is(.woocommerce-cart, .woocommerce-checkout) {
	background-color: #ffffff;
}

/* Card background */
.tutor-card, .tutor-course-loop-card, .tutor-card-body{
	background:#ffffff;
	border:1px solid #E7D9E2;
	border-radius:16px;
}
.tutor-card:hover .tutor-card-body{ background:#F0D7E5c2; }

.tutor-course-list .tutor-card:not(.tutor-no-border) , .tutor-course-list .tutor-card-body, .tutor-course-list .tutor-card-footer:not(.tutor-no-border){
	border-color: #9e3e6b;
}
.tutor-course-list .tutor-card-body {
	border: none;
	border-radius: 0;
}

.tutor-meta.tutor-mt-auto div:nth-child(2) {
	display: none !important;
}
/* Single courses page css */
.single-courses .site-content {
	position: relative;
	z-index: 0;
}
.single-courses .site-content .tutor-card-body .tutor-btn,
.status-publish .tutor-btn-primary {
	background-color: #F29A2A;
	border-color: #F29A2A;
	color: #ffffff;
	transition:all .3s;    
}
.single-courses .site-content .tutor-card-body .tutor-btn:hover,
.status-publish .tutor-btn-primary:hover {
	background-color: #D67F14;
	border-color: #D67F14;
}

.tutor-single-course-sidebar.tutor-sidebar-sticky {
	position: relative !important;
	overflow-y: unset !important;
	max-height: unset !important;
}

.tutor-course-sidebar {
	overflow: hidden;
}

li.tutor-d-flex.tutor-mt-12.tutor-course-enrollment-meta {
	display: none !important;
}
.tutor-card-footer {
	display: none;
}

p.enrolment-expire-info.tutor-fs-7.tutor-color-muted.tutor-d-flex.tutor-align-center.tutor-mt-4 {
	display: none !important;
}
header#masthead span.sep {
	display: none;
}


/* Hide author name on blog single post page */
.single-post .post-author,
.single-post .tutor-meta .author,
.single-post .entry-author,
.single-post .byline,
.single-post .posted-by {
	display: none !important;
}

/* Footer Social Medai link*/

footer ul#menu-social-media-links {
	display: flex;
	align-items: center;
	gap: 15px;
}
footer ul#menu-social-media-links > li {
	margin: 0 !important;
	display: flex;
	align-items: center;
	font-size: 0;
	line-height: 0;
}
footer ul#menu-social-media-links > li > a > i {
	line-height: normal;
	margin: 0;
	font-size: 26px;
}
footer ul#menu-social-media-links > li > a > span {
	font-size: 0;
	line-height: 0;
}
.reign-posts-nav .reign-posts-nav-thumbnail .next::before, .reign-posts-nav .reign-posts-nav-thumbnail .prev::before {
	font-size: 30px;
	width: 100%;
	height: 100%;
}

.reign-posts-nav .reign-posts-nav-thumbnail .next::before {
	content: "\f054";
}
.reign-posts-nav .reign-posts-nav-thumbnail .prev::before {
	content: "\f104";
}

@media (max-width: 959px) {
	.header-v2 #masthead .reign-fallback-header.header-mobile .reign-nav-top-bar .site-branding {
		display: block;
		margin: 0 auto;
		text-align: center;
		min-height: auto;
	}
	.reign-posts-nav .reign-posts-nav-thumbnail .next::before, .reign-posts-nav .reign-posts-nav-thumbnail .prev::before {
		font-size: 26px;       
	}

}


.type-label{
	    background-color: #9e3e6b;
    color: #fff;
    padding: 4px 11px;
    font-size: 12px;
    border-radius: 4px;
    text-transform: uppercase;
}


/* discount messages */
.custom-discount-message {
    width: 100%; 
    background-color: #9e3e6b;
    color: #ffffff;
    font-weight: 700;
    text-align: center;
    font-size: 20px;
    padding: 20px 0;
    border-radius: 0; 
    margin: 15px 0;
    box-sizing: border-box;
    display: block;
}


.custom-discount-message strong {
    color: #ffffff;
}

/*end discount messages */


/*Start- hide course filter */
.tutor-course-filter{
	display: none !important;
}
/* Force hide Tutor LMS default course filter */
body.post-type-archive-courses .tutor-course-filter,
body.post-type-archive-courses .tutor-course-filter * {
    display: none !important;
    visibility: hidden !important;
    height: 0 !important;
    overflow: hidden !important;
}

/*End- hide course filter */
/* Default color */
.hands-on-header-link a {
    color: #3b2a27;
		padding-right: 10px;
}

/* Hover */
.hands-on-header-link a:hover {
    color: #9e3e6b;
}


.shop_table th.product-quantity,.shop_table td.product-quantity{
	display: none !important;
}

.reign-header-top{
	    background:#1f2b37;
   color:#fff ;
    font-weight: bold;
    text-align: center;
    width: 100%;
    float: left;
    padding: 17px 15px;
	font-size:14px;
	letter-spacing:2px
	
}
.reign-header-top .header-top-left{
	float: left;
    text-align: center;
    width: 100%;
}
.tutor-row a.enrolled-courses-is-active {
    border-bottom: 5px solid #9e3e6b !important;
}

@media (min-width: 960px) {
    .reign-sticky-topbar .site-content {
        padding-top: 90px;
    }
}

.tutor-dashboard-menu-item.tutor-dashboard-menu-my-quiz-attempts{
	display: none !important;
}
/* a[href="https://loveandflourbypooja.com/dashboard/my-quiz-attempts/"] {
    display: none;
} */

.tutor-course-progress,.list-item-progress{
	display: none !important;
}

.attachment h1{
	display:none;
}

.tutor-course-card .tutor-card-footer .list-item-price .price {
   
    flex-direction: row !important;
}

.list-item-price .woocommerce-price-suffix {
	margin-top: 4px;
    font-size: 12px;
    color: #3B2A27;
}
/* Target single course page price */
.tutor-course-sidebar-card-pricing.tutor-d-flex::after {
    content: " (Inclusive of GST and Platform Fee)";
	margin-top: 4px;
    font-size: 12px;
    color: #3B2A27;
	    margin-left: 10px;
   
}


